# Lipa-Cart Flutter Environment Variables
# Pass these via --dart-define when building:
#   flutter run --dart-define=API_BASE_URL=http://localhost:1337 --dart-define=GOOGLE_WEB_CLIENT_ID=your_google_client_id
#
# For CI/CD (GitHub Actions), add these as repository secrets.

# Backend API base URL (no trailing slash)
API_BASE_URL=http://localhost:1337

# Sentry error tracking DSN
SENTRY_DSN=https://your-key@o123456.ingest.us.sentry.io/456789

# Sentry environment (development | staging | production)
SENTRY_ENV=development

# Google OAuth web client ID for the consent screen / prefilled sign-up
GOOGLE_WEB_CLIENT_ID=461833863082-gkset420arg3nqcip15jm9ptclom7g9e.apps.googleusercontent.com
